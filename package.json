{
    "name": "arwenis-vector-seed",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Arwenis için müşteriye/demoya özel vektör DB besleme aracı (scrape + embed + upsert). Arwenis ürününden bağımsızdır.",
    "scripts": {
        "scrape:haberturk": "node --env-file=.env scripts/sources/haberturk.mjs",
        "scrape:bloomberght": "node --env-file=.env scripts/sources/bloomberght.mjs",
        "generate:synthetic": "node --env-file=.env scripts/sources/synthetic.mjs",
        "db:rebuild": "node --env-file=.env scripts/targets/qdrant.mjs rebuild",
        "db:upsert": "node --env-file=.env scripts/targets/qdrant.mjs upsert",
        "db:clear": "node --env-file=.env scripts/targets/qdrant.mjs clear",
        "db:drop": "node --env-file=.env scripts/targets/qdrant.mjs drop"
    },
    "dependencies": {
        "entities": "^8.0.0",
        "html-to-text": "^10.0.0"
    }
}
