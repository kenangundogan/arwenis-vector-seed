{
    "name": "arwenis-vector-seed",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Arwenis için müşteriye/demoya özel vektör DB besleme aracı (scrape + embed + upsert). Arwenis ürününden bağımsızdır.",
    "scripts": {
        "scrape:haberturk": "node --env-file=.env scripts/sources/haberturk.mjs",
        "scrape:bloomberght": "node --env-file=.env scripts/sources/bloomberght.mjs",
        "generate:synthetic": "node --env-file=.env scripts/sources/synthetic.mjs",
        "db:rebuild:qdrant": "node --env-file=.env scripts/db.mjs rebuild qdrant",
        "db:rebuild:weaviate": "node --env-file=.env scripts/db.mjs rebuild weaviate",
        "db:upsert:qdrant": "node --env-file=.env scripts/db.mjs upsert qdrant",
        "db:upsert:weaviate": "node --env-file=.env scripts/db.mjs upsert weaviate",
        "db:clear:qdrant": "node --env-file=.env scripts/db.mjs clear qdrant",
        "db:clear:weaviate": "node --env-file=.env scripts/db.mjs clear weaviate",
        "db:drop:qdrant": "node --env-file=.env scripts/db.mjs drop qdrant",
        "db:drop:weaviate": "node --env-file=.env scripts/db.mjs drop weaviate"
    },
    "dependencies": {
        "entities": "^8.0.0",
        "html-to-text": "^10.0.0"
    }
}
