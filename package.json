{
    "name": "arwenis-vector-seed",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Arwenis için müşteriye/demoya özel vektör DB besleme aracı (scrape + embed + upsert). Arwenis ürününden bağımsızdır.",
    "scripts": {
        "scrape:haberturk": "node --env-file=.env scripts/sources/haberturk.mjs",
        "scrape:bloomberght": "node --env-file=.env scripts/sources/bloomberght.mjs",
        "synthetic": "node --env-file=.env scripts/sources/synthetic.mjs",
        "seed": "node --env-file=.env scripts/targets/qdrant.mjs seed",
        "all:haberturk": "node --env-file=.env scripts/sources/haberturk.mjs && node --env-file=.env scripts/targets/qdrant.mjs seed",
        "all:bloomberght": "node --env-file=.env scripts/sources/bloomberght.mjs && node --env-file=.env scripts/targets/qdrant.mjs seed",
        "all:synthetic": "node --env-file=.env scripts/sources/synthetic.mjs && node --env-file=.env scripts/targets/qdrant.mjs seed",
        "clear-points": "node --env-file=.env scripts/targets/qdrant.mjs clear",
        "delete-collection": "node --env-file=.env scripts/targets/qdrant.mjs drop"
    },
    "dependencies": {
        "entities": "^8.0.0",
        "html-to-text": "^10.0.0"
    }
}
