# Vektör DB seçimi (qdrant | weaviate) — backend komuta verilmezse varsayılan hedef
VECTOR_DB=qdrant
COLLECTION=arwenis

# Qdrant Konfigürasyonu
QDRANT_URL=http://127.0.0.1:6333
QDRANT_KEY=localkey

# Weaviate Konfigürasyonu (VECTOR_DB=weaviate ise)
WEAVIATE_URL=http://127.0.0.1:8080
WEAVIATE_KEY=

# Embedding Konfigürasyonu (Ollama veya OpenAI)
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_KEY=ollama
EMBED_MODEL=nomic-embed-text

# Besleme Konfigürasyonu
TARGET_COUNT=1000
CONTENT_CONCURRENCY=8
